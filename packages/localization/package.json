{
  "name": "@prossimo-app/localization",
  "version": "1.0.0",
  "private": true,
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./locales/*.json": "./src/locales/*.json"
  },
  "scripts": {
    "format": "prettier --check .",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "i18next": "^26.3.0",
    "react-i18next": "^17.0.8"
  },
  "devDependencies": {
    "@prossimo-app/eslint-config": "workspace:*",
    "@prossimo-app/prettier-config": "workspace:*",
    "@prossimo-app/tsconfig": "workspace:*",
    "@types/react": "~19.2.2",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": "^19.2.0"
  },
  "prettier": "@prossimo-app/prettier-config"
}
