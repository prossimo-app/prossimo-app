# Selects the Expo app variant; "development" uses dev app names, schemes, and icons.
APP_VARIANT="development"

# Optional broader app environment label used by workers when WORKER_ENV is unset.
APP_ENV="development"

# Standard Node runtime mode; workers use this as the final environment label fallback.
NODE_ENV="development"

# Local development Postgres connection string used by the API context and Drizzle Kit.
# Start the matching Postgres 18 + PostGIS container with: pnpm db:dev:start
DATABASE_URL="postgresql://prossimo:prossimo@localhost:5432/prossimo"

# API server listen port.
PORT="3000"

# WebSocket server listen port.
WS_PORT="1337"

# API server listen host.
HOST="0.0.0.0"

# Comma-separated list of allowed CORS origins for the API server; "*" allows all.
API_CORS_ORIGIN="*"

# Worker-specific environment label recorded with scheduled job runs.
WORKER_ENV="development"

# Number of days to keep ended GTFS-RT service alerts before pruning.
GTFS_REALTIME_ALERT_RETENTION_DAYS="90"

# Bearer token used by the worker when calling the app router internally.
WORKER_API_TOKEN="worker"

# Optional Expo development API base URL override. Production mobile builds use https://api.prossimo.app.
EXPO_PUBLIC_API_URL=""

# Optional Expo development WebSocket base URL override. Production mobile builds use wss://ws.prossimo.app.
EXPO_PUBLIC_WS_URL=""

# Public app store destinations used by the web /download redirect.
APP_STORE_DOWNLOAD_URL="https://apps.apple.com/it/app/prossimo/id6777119422"
GOOGLE_PLAY_DOWNLOAD_URL="https://play.google.com/store/apps/details?id=app.prossimo.app"

# Redis connection string used for caching, rate limiting, and realtime topic coordination.
# For local development, start the matching Redis container with: pnpm redis:dev:start
REDIS_URL="redis://localhost:6379"

# Google Maps API key to display maps on Android
GOOGLE_MAPS_API_KEY=""
