{
  "name": "@prossimo-app/mobile",
  "main": "index.ts",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "git clean -xdf .cache .expo .turbo android ios node_modules",
    "prebuild:ios": "dotenv -e ../../.env -- expo prebuild --platform ios --clean",
    "prebuild:ios:development": "APP_VARIANT=development dotenv -e ../../.env -- expo prebuild --platform ios --clean",
    "prebuild:android": "dotenv -e ../../.env -- expo prebuild --platform android --clean",
    "prebuild:android:development": "APP_VARIANT=development dotenv -e ../../.env -- expo prebuild --platform android --clean",
    "build:ios:local": "EAS_LOCAL_BUILD_ARTIFACTS_DIR=./dist EAS_LOCAL_BUILD_SKIP_CLEANUP=1 dotenv -e ../../.env -- eas build --platform ios --profile production --local",
    "build:android:local": "EAS_LOCAL_BUILD_ARTIFACTS_DIR=./dist EAS_LOCAL_BUILD_SKIP_CLEANUP=1 dotenv -e ../../.env -- eas build --platform android --profile production --local",
    "dev": "dotenv -e ../../.env -- expo start",
    "dev:android": "dotenv -e ../../.env -- expo start --android",
    "dev:ios": "dotenv -e ../../.env -- expo start --ios",
    "android": "dotenv -e ../../.env -- expo run:android",
    "ios": "dotenv -e ../../.env -- expo run:ios",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo-google-fonts/instrument-sans": "^0.4.2",
    "@expo-google-fonts/instrument-serif": "^0.4.1",
    "@expo/material-symbols": "^0.1.1",
    "@expo/ui": "~56.0.14",
    "@legendapp/list": "^3.0.0",
    "@prossimo-app/api": "workspace:*",
    "@prossimo-app/localization": "workspace:*",
    "@tanstack/react-query": "^5.90.12",
    "@trpc/client": "^11.17.0",
    "@trpc/tanstack-react-query": "^11.17.0",
    "expo": "~56.0.6",
    "expo-blur": "~56.0.3",
    "expo-constants": "~56.0.16",
    "expo-dev-client": "~56.0.18",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-glass-effect": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.9",
    "expo-insights": "~56.0.15",
    "expo-linking": "~56.0.12",
    "expo-localization": "~56.0.6",
    "expo-location": "~56.0.14",
    "expo-maps": "~56.0.6",
    "expo-router": "~56.2.7",
    "expo-secure-store": "56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "expo-tracking-transparency": "~56.0.5",
    "expo-updates": "~56.0.17",
    "expo-web-browser": "~56.0.5",
    "expo-widgets": "~56.0.15",
    "nativewind": "5.0.0-preview.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-css": "^3.0.7",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "sonner-native": "^0.25.1",
    "superjson": "^2.2.6"
  },
  "devDependencies": {
    "@prossimo-app/eslint-config": "workspace:*",
    "@prossimo-app/prettier-config": "workspace:*",
    "@prossimo-app/tailwind-config": "workspace:*",
    "@prossimo-app/tsconfig": "workspace:*",
    "@tailwindcss/postcss": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "~19.2.2",
    "eslint": "catalog:",
    "postcss": "^8.5.15",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@prossimo-app/prettier-config"
}
