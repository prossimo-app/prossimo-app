{
  "name": "prossimo-app",
  "private": true,
  "engines": {
    "node": "^24.16.0",
    "pnpm": "^10.34.1"
  },
  "packageManager": "pnpm@10.34.1",
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "db:dev:start": "bash ./scripts/dev-postgres.sh start",
    "db:dev:stop": "bash ./scripts/dev-postgres.sh stop",
    "db:dev:restart": "bash ./scripts/dev-postgres.sh restart",
    "db:dev:logs": "bash ./scripts/dev-postgres.sh logs",
    "db:dev:status": "bash ./scripts/dev-postgres.sh status",
    "redis:dev:start": "bash ./scripts/dev-redis.sh start",
    "redis:dev:stop": "bash ./scripts/dev-redis.sh stop",
    "redis:dev:restart": "bash ./scripts/dev-redis.sh restart",
    "redis:dev:logs": "bash ./scripts/dev-redis.sh logs",
    "redis:dev:status": "bash ./scripts/dev-redis.sh status",
    "dev": "turbo run dev --continue",
    "lint": "turbo run lint --continue -- --cache --cache-location .cache/.eslintcache",
    "lint:fix": "turbo run lint --continue -- --fix --cache --cache-location .cache/.eslintcache",
    "format": "turbo run format --continue -- --cache --cache-location .cache/.prettiercache",
    "format:fix": "turbo run format --continue -- --write --cache --cache-location .cache/.prettiercache",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@prossimo-app/prettier-config": "workspace:*",
    "@prossimo-app/tsconfig": "workspace:*",
    "prettier": "catalog:",
    "turbo": "^2.9.16",
    "dotenv-cli": "^11.0.0",
    "typescript": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "lightningcss": "1.30.1"
    }
  },
  "prettier": "@prossimo-app/prettier-config"
}
